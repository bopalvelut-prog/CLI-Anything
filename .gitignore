# Step 7: Ignore build artifacts within allowed dirs
**/__pycache__/
**/*.egg-info/
**/*.pyc
**/dist/
**/build/
**/.pytest_cache/
**/*.egg
**/*.mp4
**/*.wav
**/*.blend
**/*.xcf
**/*.mlt
**/*.drawio

# Step 8: But allow assets images
!/assets/*.png
!/assets/*.jpg

assets/gen_typing_gif.py
